# Article Claw - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# SMTP Configuration (Required for email delivery)
# =============================================================================

# SMTP Server Settings
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

# Sender Email Credentials
SMTP_USER=your-email@qq.com
SMTP_PASS=your-auth-code-or-password

# =============================================================================
# AI API Keys (Optional but recommended for better Chinese summaries)
# =============================================================================

# Kimi AI (Moonshot) - Recommended for Chinese
# Get your key at: https://www.moonshot.cn/
MOONSHOT_API_KEY=sk-your-kimi-api-key

# OpenAI - Alternative option
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# arXiv Configuration (Optional)
# =============================================================================

# Contact email for arXiv API politeness
ARXIV_CONTACT_EMAIL=your-email@example.com

# =============================================================================
# Notes:
# =============================================================================
# 1. Copy this file to .env and fill in your actual values
# 2. .env is ignored by Git - your secrets are safe
# 3. For QQ/163 mail, use "Authorization Code" not login password
# 4. For Gmail, use "App Password" not login password
# 5. Recipients are configured in config/recipients.json
