{
  "project": {
    "name": "paper_claw",
    "title": "Paper Claw",
    "description": "Multi-source paper digest generator with AI-powered summaries",
    "timezone": "Asia/Shanghai",
    "version": "2.0.0"
  },
  "language": {
    "default": "zh",
    "supported": [
      "zh",
      "en",
      "ja",
      "ko",
      "de",
      "fr",
      "es"
    ]
  },
  "sources": {
    "arxiv": {
      "enabled": true,
      "name": "arXiv",
      "url": "https://arxiv.org",
      "categories": [
        {
          "id": "cs.SD",
          "name": "Sound",
          "url": "https://arxiv.org/list/cs.SD/recent"
        },
        {
          "id": "eess.AS",
          "name": "Audio and Speech Processing",
          "url": "https://arxiv.org/list/eess.AS/recent"
        }
      ]
    }
  },
  "classification": {
    "categories": [
      {
        "name": "Speech LLM",
        "labels": {
          "zh": "语音大模型",
          "en": "Speech LLM",
          "ja": "音声大規模言語モデル"
        },
        "keywords": [
          "speech llm",
          "audio llm",
          "spoken language model",
          "speech language model",
          "voice llm",
          "audio-language model",
          "speech understanding",
          "spoken dialogue"
        ]
      },
      {
        "name": "ASR",
        "labels": {
          "zh": "语音识别",
          "en": "Speech Recognition",
          "ja": "音声認識"
        },
        "keywords": [
          "automatic speech recognition",
          "asr system",
          "speech-to-text",
          "speech transcription",
          "end-to-end asr",
          "conformer",
          "wav2vec",
          "hubert",
          "whisper"
        ]
      },
      {
        "name": "TTS",
        "labels": {
          "zh": "语音合成",
          "en": "Speech Synthesis",
          "ja": "音声合成"
        },
        "keywords": [
          "text-to-speech",
          "tts system",
          "speech synthesis",
          "voice synthesis",
          "neural vocoder",
          "acoustic model",
          "tacotron",
          "fastspeech",
          "mel-spectrogram generation"
        ]
      },
      {
        "name": "Enhancement",
        "labels": {
          "zh": "语音增强",
          "en": "Enhancement",
          "ja": "音声強調"
        },
        "keywords": [
          "speech enhancement",
          "noise reduction",
          "speech denoising",
          "audio enhancement",
          "dereverberation",
          "source separation",
          "beamforming",
          "speech separation"
        ]
      },
      {
        "name": "SLU",
        "labels": {
          "zh": "口语理解",
          "en": "Spoken Language Understanding",
          "ja": "音声言語理解"
        },
        "keywords": [
          "spoken language understanding",
          "intent recognition",
          "slot filling",
          "spoken nlu",
          "semantic parsing",
          "dialogue system",
          "spoken command"
        ]
      },
      {
        "name": "Paralinguistics",
        "labels": {
          "zh": "副语言学",
          "en": "Paralinguistics",
          "ja": "副言語学"
        },
        "keywords": [
          "emotion recognition",
          "speaker verification",
          "speaker identification",
          "speaker recognition",
          "age estimation",
          "gender recognition",
          "stress detection"
        ]
      },
      {
        "name": "Audio",
        "labels": {
          "zh": "通用音频",
          "en": "General Audio",
          "ja": "一般音声"
        },
        "keywords": [
          "audio classification",
          "sound event detection",
          "audio tagging",
          "acoustic scene",
          "music information retrieval",
          "audio generation",
          "sound synthesis"
        ]
      }
    ]
  },
  "llm": {
    "default_provider": "deepseek",
    "providers": {
      "deepseek": {
        "name": "DeepSeek (SJTU)",
        "api_base": "https://models.sjtu.edu.cn/api/v1",
        "model": "deepseek-v3",
        "env_key": "DEEPSEEK_API_KEY",
        "max_retries": 3,
        "timeout": 90
      },
      "kimi": {
        "name": "Kimi AI (Moonshot)",
        "api_base": "https://api.moonshot.cn/v1",
        "model": "moonshot-v1-8k",
        "env_key": "MOONSHOT_API_KEY"
      }
    },
    "fallback_chain": [
      "deepseek",
      "kimi",
      "rule_based"
    ]
  }
}