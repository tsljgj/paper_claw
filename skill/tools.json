{
  "name": "paper_claw",
  "version": "1.0.0",
  "description": "Fetch, classify, and summarize arXiv papers in speech & audio domains",
  "author": "Article Claw Team",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/paper_claw",
  "tools": [
    {
      "name": "fetch_papers",
      "description": "Fetch papers from arXiv for a specific date or date range",
      "parameters": {
        "type": "object",
        "properties": {
          "day": {
            "type": "string",
            "description": "Specific date in YYYY-MM-DD format",
            "format": "date"
          },
          "start_date": {
            "type": "string",
            "description": "Start date for range in YYYY-MM-DD format",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "description": "End date for range in YYYY-MM-DD format",
            "format": "date"
          }
        },
        "oneOf": [
          {"required": ["day"]},
          {"required": ["start_date", "end_date"]}
        ]
      },
      "returns": {
        "type": "object",
        "description": "Path to generated digest files",
        "properties": {
          "markdown_path": {
            "type": "string",
            "description": "Path to Markdown digest file"
          },
          "json_path": {
            "type": "string",
            "description": "Path to JSON data file"
          },
          "paper_count": {
            "type": "integer",
            "description": "Number of papers fetched"
          }
        }
      }
    },
    {
      "name": "send_digest",
      "description": "Send email digest to configured recipients",
      "parameters": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Date of digest to send in YYYY-MM-DD format",
            "format": "date"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether email was sent successfully"
          },
          "recipients": {
            "type": "array",
            "items": {"type": "string"},
            "description": "List of recipient emails"
          },
          "message": {
            "type": "string",
            "description": "Status message"
          }
        }
      }
    },
    {
      "name": "configure_categories",
      "description": "Update paper classification categories",
      "parameters": {
        "type": "object",
        "properties": {
          "categories": {
            "type": "array",
            "description": "List of category definitions",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Category name in English"
                },
                "label_zh": {
                  "type": "string",
                  "description": "Category label in Chinese"
                },
                "keywords": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "Keywords for classification"
                }
              },
              "required": ["name", "label_zh", "keywords"]
            }
          }
        },
        "required": ["categories"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "message": {"type": "string"}
        }
      }
    },
    {
      "name": "configure_recipients",
      "description": "Update email recipients",
      "parameters": {
        "type": "object",
        "properties": {
          "recipients": {
            "type": "array",
            "description": "List of recipient definitions",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "description": "Recipient email address",
                  "format": "email"
                },
                "name": {
                  "type": "string",
                  "description": "Recipient name"
                },
                "enabled": {
                  "type": "boolean",
                  "description": "Whether this recipient is enabled",
                  "default": true
                }
              },
              "required": ["email", "name"]
            }
          }
        },
        "required": ["recipients"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "recipient_count": {"type": "integer"},
          "message": {"type": "string"}
        }
      }
    },
    {
      "name": "get_digest_content",
      "description": "Get the content of a generated digest",
      "parameters": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Date of digest in YYYY-MM-DD format",
            "format": "date"
          },
          "format": {
            "type": "string",
            "enum": ["markdown", "json", "summary"],
            "description": "Format to retrieve",
            "default": "summary"
          }
        },
        "required": ["date"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "content": {"type": "string"},
          "format": {"type": "string"},
          "paper_count": {"type": "integer"},
          "categories": {"type": "array"}
        }
      }
    },
    {
      "name": "schedule_digest",
      "description": "Schedule automatic daily digest generation",
      "parameters": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable or disable scheduled runs"
          },
          "time": {
            "type": "string",
            "description": "Time to run daily in HH:MM format (24h)",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
          }
        },
        "required": ["enabled"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "message": {"type": "string"},
          "schedule": {"type": "string"}
        }
      }
    }
  ],
  "config": {
    "env_file": ".env",
    "config_dir": "config",
    "output_dir": "content/posts",
    "data_dir": "data/processed"
  },
  "examples": [
    {
      "description": "Fetch papers for a specific date",
      "command": "python scripts/main.py --day 2026-03-10"
    },
    {
      "description": "Fetch papers for a date range",
      "command": "python scripts/main.py --start-date 2026-03-01 --end-date 2026-03-10"
    },
    {
      "description": "View paper count from JSON",
      "command": "jq '.summary.total' data/processed/2026-03-10.json"
    }
  ]
}
