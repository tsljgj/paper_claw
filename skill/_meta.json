{
  "slug": "article_claw",
  "version": "1.0.0",
  "author": "Article Claw Team",
  "license": "MIT",
  "tags": ["arxiv", "papers", "research", "speech", "audio", "digest", "ai", "kimi"],
  "requires": {
    "python": ">=3.11",
    "packages": ["requests", "feedparser", "python-dateutil", "jinja2"]
  },
  "env": {
    "required": ["SMTP_HOST", "SMTP_PORT", "SMTP_USER", "SMTP_PASS"],
    "optional": ["MOONSHOT_API_KEY", "OPENAI_API_KEY", "ARXIV_CONTACT_EMAIL"]
  },
  "config": {
    "files": ["config/default.json", "config/recipients.json"],
    "templates": ["config/recipients.example.json", ".env.example"]
  }
}
