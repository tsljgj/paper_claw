<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ project.title }} - {{ window.end[:10] }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 20px;
      line-height: 1.6;
      color: #333;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 30px;
      text-align: center;
    }
    .header img {
      width: 80px;
      height: 80px;
      margin-bottom: 15px;
      border-radius: 12px;
      background: white;
      padding: 8px;
    }
    .header h1 {
      font-size: 28px;
      margin-bottom: 8px;
      font-weight: 700;
    }
    .header .date {
      font-size: 16px;
      opacity: 0.9;
    }
    .header .github-link {
      display: inline-block;
      margin-top: 15px;
      padding: 8px 16px;
      background: rgba(255,255,255,0.2);
      color: white;
      text-decoration: none;
      border-radius: 20px;
      font-size: 14px;
      transition: background 0.3s;
    }
    .header .github-link:hover {
      background: rgba(255,255,255,0.3);
    }
    .notice-box {
      background: #e7f3ff;
      border-left: 4px solid #2196F3;
      padding: 15px 20px;
      margin: 20px 30px;
      border-radius: 8px;
    }
    .notice-box p {
      color: #1976D2;
      font-size: 14px;
      margin: 0;
    }
    .summary {
      padding: 30px;
      background: #f8f9fa;
      border-bottom: 1px solid #e9ecef;
    }
    .summary h2 {
      color: #495057;
      font-size: 20px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }
    .stat-card {
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      text-align: center;
    }
    .stat-card .number {
      font-size: 32px;
      font-weight: 700;
      color: #667eea;
    }
    .stat-card .label {
      color: #6c757d;
      font-size: 14px;
      margin-top: 5px;
    }
    .category-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 15px;
    }
    .category-tag {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
    }
    .content {
      padding: 30px;
    }
    .category-section {
      margin-bottom: 35px;
    }
    .category-title {
      color: #495057;
      font-size: 20px;
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 3px solid #667eea;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .paper-count {
      background: #667eea;
      color: white;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 14px;
    }
    .paper-card {
      background: #f8f9fa;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 15px;
      border-left: 4px solid #667eea;
    }
    .paper-header {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
    }
    .paper-index {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
      flex-shrink: 0;
    }
    .paper-title {
      font-size: 16px;
      font-weight: 600;
      color: #212529;
      line-height: 1.4;
      flex: 1;
    }
    .paper-meta {
      color: #6c757d;
      font-size: 13px;
      margin-bottom: 12px;
      padding-left: 38px;
    }
    .paper-abstract {
      color: #495057;
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 15px;
      padding: 15px;
      background: white;
      border-radius: 8px;
      border: 1px solid #e9ecef;
    }
    .abstract-label {
      font-weight: 600;
      color: #667eea;
      margin-bottom: 8px;
      display: block;
    }
    .review-box {
      background: white;
      border-radius: 8px;
      padding: 15px;
      margin-top: 10px;
      border: 1px solid #e9ecef;
    }
    .review-item {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 14px;
      line-height: 1.6;
    }
    .review-item:last-child { margin-bottom: 0; }
    .review-label {
      color: #667eea;
      font-weight: 600;
      min-width: 80px;
      flex-shrink: 0;
    }
    .review-content {
      color: #495057;
      flex: 1;
    }
    .arxiv-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 12px;
      padding: 8px 16px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      border-radius: 6px;
      transition: transform 0.2s;
    }
    .arxiv-link:hover { transform: translateY(-1px); }
    .empty-notice {
      text-align: center;
      padding: 30px;
      color: #6c757d;
      background: #f8f9fa;
      border-radius: 12px;
    }
    .toc {
      background: white;
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .toc h3 {
      color: #495057;
      font-size: 16px;
      margin-bottom: 15px;
    }
    .toc-list {
      list-style: none;
    }
    .toc-item {
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .toc-item:last-child { border-bottom: none; }
    .toc-link {
      color: #667eea;
      text-decoration: none;
      font-size: 14px;
    }
    .toc-link:hover { text-decoration: underline; }
    .toc-count {
      background: #e9ecef;
      color: #495057;
      padding: 2px 10px;
      border-radius: 10px;
      font-size: 12px;
    }
    .footer {
      background: #f8f9fa;
      padding: 20px 30px;
      text-align: center;
      border-top: 1px solid #e9ecef;
    }
    .footer p {
      color: #6c757d;
      font-size: 13px;
    }
    .footer a {
      color: #667eea;
      text-decoration: none;
    }
    .attachment-notice {
      background: #fff3e0;
      border: 2px dashed #ff9800;
      border-radius: 12px;
      padding: 20px;
      margin: 20px 30px;
      text-align: center;
    }
    .attachment-notice h4 {
      color: #e65100;
      margin-bottom: 10px;
      font-size: 16px;
    }
    .attachment-notice p {
      color: #f57c00;
      font-size: 14px;
      margin: 0;
    }
    @media (max-width: 600px) {
      body { padding: 10px; }
      .header { padding: 20px; }
      .header img { width: 60px; height: 60px; }
      .summary, .content { padding: 20px; }
      .stats-grid { grid-template-columns: 1fr; }
      .paper-header { flex-direction: column; }
      .paper-meta { padding-left: 0; }
      .notice-box, .attachment-notice { margin: 15px 20px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header with Logo -->
    <div class="header">
      <img src="https://raw.githubusercontent.com/PigeonDan1/paper_claw/main/assets/logo_icon.png" alt="Article Claw Logo">
      <h1>📰 {{ project.title }}</h1>
      <div class="date">{{ window.end[:10] }}</div>
      <a href="https://github.com/PigeonDan1/paper_claw" class="github-link" target="_blank">
        ⭐ Star us on GitHub
      </a>
    </div>

    <!-- Attachment Notice -->
    <div class="attachment-notice">
      <h4>📎 完整日报附件</h4>
      <p>此邮件包含 {{ summary.total }} 篇论文的完整信息。<br>
      详细内容请查看邮件附件中的 Markdown 文件。</p>
    </div>

    <!-- Notice Box -->
    <div class="notice-box">
      <p>💡 <strong>提示：</strong>这是一个自动生成的研究日报。如需自定义分类、更换语言或配置其他功能，请访问我们的 <a href="https://github.com/PigeonDan1/paper_claw" target="_blank" style="color: #1976D2; text-decoration: underline;">GitHub 仓库</a> 获取完整文档。</p>
    </div>

    <!-- Summary -->
    <div class="summary">
      <h2>📊 今日速览</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="number">{{ summary.total }}</div>
          <div class="label">论文总数</div>
        </div>
        <div class="stat-card">
          <div class="number">{{ summary.counts | length }}</div>
          <div class="label">分类数量</div>
        </div>
      </div>
      
      <div class="category-list">
        {% for category, count in summary.counts.items() %}
        <span class="category-tag">{{ category }}: {{ count }}</span>
        {% endfor %}
      </div>

      {% if summary.headline %}
      <p style="margin-top: 20px; color: #495057; font-style: italic;">💡 {{ summary.headline }}</p>
      {% endif %}
    </div>

    <!-- Content Preview (First 3 papers) -->
    <div class="content">
      <div class="toc">
        <h3>📑 分类导航（邮件中显示前 3 篇预览）</h3>
        <ul class="toc-list">
          {% for category, items in grouped.items() %}
          <li class="toc-item">
            <span class="toc-link">{{ category }}</span>
            <span class="toc-count">{{ items | length }} 篇</span>
          </li>
          {% endfor %}
        </ul>
      </div>

      {% for category, items in grouped.items() %}
      <div class="category-section">
        <h3 class="category-title">
          🏷️ {{ category }}
          <span class="paper-count">{{ items | length }} 篇</span>
        </h3>
        
        {% if items %}
          {# Show only first 3 papers in email body #}
          {% for paper in items[:3] %}
          <div class="paper-card">
            <div class="paper-header">
              <span class="paper-index">{{ loop.index }}</span>
              <div class="paper-title">{{ paper.title_en }}</div>
            </div>
            
            <div class="paper-meta">
              {% if paper.authors %}👤 {{ paper.authors | join(", ") }}{% endif %}
            </div>
            
            <div class="paper-abstract">
              <span class="abstract-label">📝 英文摘要</span>
              {{ paper.abstract_en[:300] }}{% if paper.abstract_en | length > 300 %}...{% endif %}
            </div>
            
            <div class="review-box">
              <div class="review-item">
                <span class="review-label">🇨🇳 中文总结</span>
                <span class="review-content">{{ paper.review.summary }}</span>
              </div>
            </div>
            
            <a href="{{ paper.arxiv_url }}" class="arxiv-link">🔗 查看原文 →</a>
          </div>
          {% endfor %}
          
          {% if items | length > 3 %}
          <p style="text-align: center; color: #6c757d; font-size: 14px; padding: 15px; background: #f8f9fa; border-radius: 8px;">
            📎 还有 {{ items | length - 3 }} 篇论文，请查看邮件附件
          </p>
          {% endif %}
        {% else %}
          <div class="empty-notice">📭 今日该分类暂无新论文</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Generated by <a href="https://github.com/PigeonDan1/paper_claw" target="_blank">Article Claw</a> · {{ window.end[:10] }}</p>
      <p style="margin-top: 5px; font-size: 12px;">
        📎 完整日报请查看邮件附件 | ⭐ <a href="https://github.com/PigeonDan1/paper_claw" target="_blank">GitHub 仓库</a>
      </p>
    </div>
  </div>
</body>
</html>
