<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>arXiv Digest — {{ window.end[:10] }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f4f5f7;
      color: #1a1a1a;
      font-size: 16px;
      line-height: 1.7;
      padding: 28px 14px;
    }
    .container {
      max-width: 760px; margin: 0 auto;
      background: #ffffff; border-radius: 14px;
      padding: 36px 40px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .header { border-bottom: 2px solid #ececef; padding-bottom: 22px; margin-bottom: 18px; }
    .header h1 { font-size: 30px; font-weight: 700; color: #111; letter-spacing: -0.01em; }
    .header .meta { font-size: 16px; color: #888; margin-top: 8px; }

    .toc { font-size: 15px; color: #444; margin: 22px 0 8px; }
    .toc .chip {
      display: inline-block; background: #f0f2f5; color: #333;
      padding: 5px 12px; border-radius: 14px; margin: 0 6px 8px 0; font-weight: 500;
    }

    /* Category headings */
    .category { margin-top: 40px; }
    .category h2 {
      font-size: 20px; font-weight: 700; color: #111;
      border-bottom: 3px solid #2563eb; padding-bottom: 8px; margin-bottom: 6px;
    }

    /* Paper blocks */
    .paper { padding: 24px 0; border-bottom: 1px solid #eee; }
    .paper:last-child { border-bottom: none; }
    .paper-title { font-size: 20px; font-weight: 700; color: #111; line-height: 1.45; }
    .paper-title .num { color: #bbb; font-weight: 700; margin-right: 8px; }
    .deep-badge {
      display: inline-block; font-size: 12px; font-weight: 700; color: #6d28d9;
      background: #f3edff; padding: 3px 9px; border-radius: 10px; margin-left: 8px;
      vertical-align: middle;
    }
    .why {
      font-size: 15px; color: #444; margin-top: 12px;
      padding: 11px 16px; background: #eff4ff; border-left: 4px solid #2563eb; border-radius: 4px;
    }
    .why .score { font-weight: 700; color: #2563eb; }
    .summary-zh { font-size: 16px; color: #2a2a2a; margin-top: 14px; line-height: 1.8; }
    .take {
      font-size: 15px; line-height: 1.75; margin-top: 12px;
      padding: 10px 14px; border-radius: 6px;
    }
    .take .tag { font-weight: 700; margin-right: 6px; }
    .take.done { background: #f0faf3; border-left: 4px solid #1f9d57; color: #1f5135; }
    .take.done .tag { color: #1f9d57; }
    .take.gap  { background: #fff6f0; border-left: 4px solid #e07b39; color: #6b3a16; }
    .take.gap .tag { color: #c75a12; }
    .abstract { font-size: 14px; color: #999; margin-top: 14px; line-height: 1.65; }
    .paper-meta { font-size: 14px; color: #aaa; margin-top: 12px; }
    .paper-link { margin-top: 14px; }
    .paper-link a {
      display: inline-block; font-size: 14px; font-weight: 600;
      color: #2563eb; text-decoration: none;
      padding: 7px 16px; border: 1px solid #2563eb; border-radius: 8px;
    }

    /* Watched-author section — visually prominent */
    .watched {
      margin: 8px 0 12px; padding: 24px 26px;
      background: #fffbeb; border: 2px solid #f5c451; border-radius: 12px;
    }
    .watched h2 {
      font-size: 21px; font-weight: 800; color: #92590b;
      border: none; padding: 0; margin-bottom: 6px;
    }
    .watched .sub { font-size: 14px; color: #a9760a; margin-bottom: 4px; }
    .watched .paper { border-bottom-color: #f0e0a8; }
    .watched-by {
      display: inline-block; font-size: 14px; font-weight: 700; color: #92590b;
      background: #fde9a8; padding: 4px 12px; border-radius: 12px; margin-top: 10px;
    }

    .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #eee; font-size: 14px; color: #aaa; }
    @media (max-width: 600px) {
      body { padding: 14px 8px; }
      .container { padding: 24px 20px; border-radius: 10px; }
      .header h1 { font-size: 25px; }
      .paper-title { font-size: 18px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>arXiv Daily Digest</h1>
      <div class="meta">{{ window.end[:10] }} · {{ summary.total }} selected papers</div>
    </div>

    {% if watched %}
    <div class="watched">
      <h2>⭐ Authors You Follow</h2>
      <div class="sub">Papers from researchers you track</div>
      {% for paper in watched %}
      <div class="paper">
        <div class="paper-title"><span class="num">{{ loop.index }}.</span>{{ paper.title_en }}</div>
        <div class="watched-by">👤 {{ paper.watched_authors | join(", ") }}</div>
        {% if paper.review.summary %}
        <div class="summary-zh">{{ paper.review.summary }}</div>
        {% endif %}
        {% if paper.review.achieved %}
        <div class="take done"><span class="tag">{% if paper.language == 'en' %}✓ Achieved:{% else %}✓ 做到了：{% endif %}</span>{{ paper.review.achieved }}</div>
        {% endif %}
        {% if paper.review.limitations %}
        <div class="take gap"><span class="tag">{% if paper.language == 'en' %}△ Gaps / not done:{% else %}△ 还能做但没做：{% endif %}</span>{{ paper.review.limitations }}</div>
        {% endif %}
        {% if paper.abstract_en %}
        <div class="abstract">{{ paper.abstract_en[:320] }}{% if paper.abstract_en | length > 320 %}…{% endif %}</div>
        {% endif %}
        {% if paper.authors %}
        <div class="paper-meta">{{ paper.authors[:5] | join(", ") }}{% if paper.authors | length > 5 %} et al.{% endif %}</div>
        {% endif %}
        <div class="paper-link"><a href="{{ paper.arxiv_url }}">Read on arXiv →</a></div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if grouped %}
    <div class="toc">
      {% for category, items in grouped.items() %}
      <span class="chip">{{ items[0].category_label | default(category, true) }} · {{ items | length }}</span>
      {% endfor %}
    </div>

    {% for category, items in grouped.items() %}
    <div class="category">
      <h2>{{ items[0].category_label | default(category, true) }}</h2>
      {% for paper in items %}
      <div class="paper">
        <div class="paper-title"><span class="num">{{ loop.index }}.</span>{{ paper.title_en }}{% if paper.deep_read %}<span class="deep-badge">🔍 {% if paper.language == 'en' %}Deep read{% else %}深读{% endif %}</span>{% endif %}</div>
        {% if paper.relevance_reason %}
        <div class="why">{% if paper.relevance_score is not none %}<span class="score">{{ paper.relevance_score }}/10</span> — {% endif %}{{ paper.relevance_reason }}</div>
        {% endif %}
        {% if paper.review.summary %}
        <div class="summary-zh">{{ paper.review.summary }}</div>
        {% endif %}
        {% if paper.review.achieved %}
        <div class="take done"><span class="tag">{% if paper.language == 'en' %}✓ Achieved:{% else %}✓ 做到了：{% endif %}</span>{{ paper.review.achieved }}</div>
        {% endif %}
        {% if paper.review.limitations %}
        <div class="take gap"><span class="tag">{% if paper.language == 'en' %}△ Gaps / not done:{% else %}△ 还能做但没做：{% endif %}</span>{{ paper.review.limitations }}</div>
        {% endif %}
        {% if paper.abstract_en %}
        <div class="abstract">{{ paper.abstract_en[:320] }}{% if paper.abstract_en | length > 320 %}…{% endif %}</div>
        {% endif %}
        {% if paper.authors %}
        <div class="paper-meta">{{ paper.authors[:5] | join(", ") }}{% if paper.authors | length > 5 %} et al.{% endif %}</div>
        {% endif %}
        <div class="paper-link"><a href="{{ paper.arxiv_url }}">Read on arXiv →</a></div>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
    {% elif not watched %}
    <p style="color:#888;font-size:16px;">No relevant papers found in today's window.</p>
    {% endif %}

    <div class="footer">
      Full list attached as Markdown. Generated by paper_claw{% if model_name %} · {{ model_name }}{% endif %}.
    </div>
  </div>
</body>
</html>
