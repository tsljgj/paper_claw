<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ project.title }} - {{ window.end[:10] }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 20px;
      line-height: 1.6;
      color: #333;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 40px 30px;
      text-align: center;
    }
    .header h1 {
      font-size: 28px;
      margin-bottom: 8px;
      font-weight: 700;
    }
    .header .date {
      font-size: 16px;
      opacity: 0.9;
    }
    .summary {
      padding: 30px;
      background: #f8f9fa;
      border-bottom: 1px solid #e9ecef;
    }
    .summary h2 {
      color: #495057;
      font-size: 20px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }
    .stat-card {
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      text-align: center;
    }
    .stat-card .number {
      font-size: 32px;
      font-weight: 700;
      color: #667eea;
    }
    .stat-card .label {
      color: #6c757d;
      font-size: 14px;
      margin-top: 5px;
    }
    .category-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 15px;
    }
    .category-tag {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
    }
    .content {
      padding: 30px;
    }
    .category-section {
      margin-bottom: 35px;
    }
    .category-title {
      color: #495057;
      font-size: 20px;
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 3px solid #667eea;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .paper-count {
      background: #667eea;
      color: white;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 14px;
    }
    .paper-card {
      background: #f8f9fa;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 15px;
      border-left: 4px solid #667eea;
    }
    .paper-header {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
    }
    .paper-index {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
      flex-shrink: 0;
    }
    .paper-title {
      font-size: 16px;
      font-weight: 600;
      color: #212529;
      line-height: 1.4;
      flex: 1;
    }
    .paper-meta {
      color: #6c757d;
      font-size: 13px;
      margin-bottom: 12px;
      padding-left: 38px;
    }
    .paper-abstract {
      color: #495057;
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 15px;
      padding: 15px;
      background: white;
      border-radius: 8px;
      border: 1px solid #e9ecef;
    }
    .abstract-label {
      font-weight: 600;
      color: #667eea;
      margin-bottom: 8px;
      display: block;
    }
    .review-box {
      background: white;
      border-radius: 8px;
      padding: 15px;
      margin-top: 10px;
      border: 1px solid #e9ecef;
    }
    .review-item {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 14px;
      line-height: 1.6;
    }
    .review-item:last-child { margin-bottom: 0; }
    .review-label {
      color: #667eea;
      font-weight: 600;
      min-width: 80px;
      flex-shrink: 0;
    }
    .review-content {
      color: #495057;
      flex: 1;
    }
    .arxiv-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 12px;
      padding: 8px 16px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      border-radius: 6px;
      transition: transform 0.2s;
    }
    .arxiv-link:hover { transform: translateY(-1px); }
    .empty-notice {
      text-align: center;
      padding: 30px;
      color: #6c757d;
      background: #f8f9fa;
      border-radius: 12px;
    }
    .toc {
      background: white;
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .toc h3 {
      color: #495057;
      font-size: 16px;
      margin-bottom: 15px;
    }
    .toc-list {
      list-style: none;
    }
    .toc-item {
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .toc-item:last-child { border-bottom: none; }
    .toc-link {
      color: #667eea;
      text-decoration: none;
      font-size: 14px;
    }
    .toc-link:hover { text-decoration: underline; }
    .toc-count {
      background: #e9ecef;
      color: #495057;
      padding: 2px 10px;
      border-radius: 10px;
      font-size: 12px;
    }
    .footer {
      background: #f8f9fa;
      padding: 20px 30px;
      text-align: center;
      border-top: 1px solid #e9ecef;
    }
    .footer p {
      color: #6c757d;
      font-size: 13px;
    }
    .footer a {
      color: #667eea;
      text-decoration: none;
    }
    @media (max-width: 600px) {
      body { padding: 10px; }
      .header { padding: 30px 20px; }
      .summary, .content { padding: 20px; }
      .stats-grid { grid-template-columns: 1fr; }
      .paper-header { flex-direction: column; }
      .paper-meta { padding-left: 0; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1>📰 {{ project.title }}</h1>
      <div class="date">{{ window.end[:10] }}</div>
    </div>

    <!-- Summary -->
    <div class="summary">
      <h2>📊 今日速览</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="number">{{ summary.total }}</div>
          <div class="label">论文总数</div>
        </div>
        <div class="stat-card">
          <div class="number">{{ summary.counts | length }}</div>
          <div class="label">分类数量</div>
        </div>
      </div>
      
      <div class="category-list">
        {% for category, count in summary.counts.items() %}
        <span class="category-tag">{{ category }}: {{ count }}</span>
        {% endfor %}
      </div>

      {% if summary.headline %}
      <p style="margin-top: 20px; color: #495057; font-style: italic;">💡 {{ summary.headline }}</p>
      {% endif %}
    </div>

    <!-- Content -->
    <div class="content">
      <!-- Table of Contents -->
      <div class="toc">
        <h3>📑 分类导航</h3>
        <ul class="toc-list">
          {% for category, items in grouped.items() %}
          <li class="toc-item">
            <a href="#cat-{{ loop.index }}" class="toc-link">{{ category }}</a>
            <span class="toc-count">{{ items | length }} 篇</span>
          </li>
          {% endfor %}
        </ul>
      </div>

      {% for category, items in grouped.items() %}
      <div class="category-section" id="cat-{{ loop.index }}">
        <h3 class="category-title">
          🏷️ {{ category }}
          <span class="paper-count">{{ items | length }} 篇</span>
        </h3>
        
        {% if items %}
          {% for paper in items %}
          <div class="paper-card">
            <div class="paper-header">
              <span class="paper-index">{{ loop.index }}</span>
              <div class="paper-title">{{ paper.title_en }}</div>
            </div>
            
            <div class="paper-meta">
              {% if paper.authors %}👤 {{ paper.authors | join(", ") }}{% endif %}
              {% if paper.affiliations %}<br>🏢 {{ paper.affiliations | join("; ") }}{% endif %}
            </div>
            
            <div class="paper-abstract">
              <span class="abstract-label">📝 英文摘要</span>
              {{ paper.abstract_en }}
            </div>
            
            <div class="review-box">
              <div class="review-item">
                <span class="review-label">🇨🇳 中文总结</span>
                <span class="review-content">{{ paper.review.summary_zh }}</span>
              </div>
              <div class="review-item">
                <span class="review-label">📖 可读性</span>
                <span class="review-content">{{ paper.review.readability_zh }}</span>
              </div>
            </div>
            
            <a href="{{ paper.arxiv_url }}" class="arxiv-link">🔗 查看原文 →</a>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty-notice">📭 今日该分类暂无新论文</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Generated by <a href="#">Article Claw</a> · {{ window.end[:10] }}</p>
      <p style="margin-top: 5px; font-size: 12px;">
        📧 此邮件包含 {{ summary.total }} 篇论文的完整信息
      </p>
    </div>
  </div>
</body>
</html>
