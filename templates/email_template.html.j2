<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ project.title }} - {{ window.end[:10] }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      padding: 20px;
      line-height: 1.6;
      color: #333;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    /* Header - 使用浅色背景确保文字清晰 */
    .header {
      background: #edf2f7;
      border-bottom: 3px solid #4a5568;
      padding: 25px 30px;
      text-align: center;
    }
    .header img {
      width: 48px;
      height: 48px;
      margin-bottom: 12px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .header h1 {
      font-size: 26px;
      font-weight: 700;
      color: #1a202c;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .header-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 8px;
    }
    .header .date {
      font-size: 14px;
      color: #4a5568;
      background: #fff;
      padding: 4px 12px;
      border-radius: 16px;
      border: 1px solid #e2e8f0;
    }
    .powered-by {
      font-size: 12px;
      color: #fff;
      background: #2d3748;
      padding: 4px 12px;
      border-radius: 16px;
      font-weight: 600;
      font-family: Arial, sans-serif;
    }
    .github-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 12px;
      padding: 8px 16px;
      background: #1a202c;
      color: #fff;
      text-decoration: none;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
    }
    /* Notice boxes */
    .notice-box {
      background: #e6f3ff;
      border-left: 4px solid #4a90e2;
      padding: 15px 20px;
      margin: 20px 30px;
      border-radius: 0 8px 8px 0;
    }
    .notice-box p {
      color: #2c5282;
      font-size: 14px;
      margin: 0;
    }
    .notice-box a {
      color: #2b6cb0;
      text-decoration: underline;
    }
    /* Summary */
    .summary {
      padding: 25px 30px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }
    .summary h2 {
      color: #2d3748;
      font-size: 18px;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin-bottom: 15px;
    }
    .stat-card {
      background: #fff;
      padding: 15px;
      border-radius: 10px;
      text-align: center;
      border: 1px solid #e2e8f0;
    }
    .stat-card .number {
      font-size: 28px;
      font-weight: 700;
      color: #2d3748;
    }
    .stat-card .label {
      color: #718096;
      font-size: 13px;
      margin-top: 4px;
    }
    .category-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }
    .category-tag {
      background: #4a5568;
      color: #fff;
      padding: 6px 12px;
      border-radius: 16px;
      font-size: 12px;
      font-weight: 500;
      font-family: Arial, sans-serif;
    }
    /* Content */
    .content {
      padding: 25px 30px;
    }
    .toc {
      background: #f8fafc;
      padding: 15px 20px;
      border-radius: 10px;
      margin-bottom: 25px;
      border: 1px solid #e2e8f0;
    }
    .toc h3 {
      color: #2d3748;
      font-size: 15px;
      margin-bottom: 12px;
    }
    .toc-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 8px;
    }
    .toc-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: #fff;
      border-radius: 6px;
      border: 1px solid #e2e8f0;
    }
    .toc-link {
      color: #4a5568;
      font-size: 13px;
    }
    .toc-count {
      background: #4a5568;
      color: #fff;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 600;
      font-family: Arial, sans-serif;
    }
    /* Category Section */
    .category-section {
      margin-bottom: 30px;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      overflow: hidden;
    }
    .category-header {
      background: #4a5568;
      color: #fff;
      padding: 12px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: Arial, sans-serif;
    }
    .category-title {
      font-size: 16px;
      font-weight: 600;
      flex: 1;
    }
    .paper-count {
      background: rgba(255,255,255,0.2);
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
    }
    .category-body {
      padding: 20px;
    }
    /* Paper Card */
    .paper-card {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 18px;
      margin-bottom: 15px;
    }
    .paper-card:last-child {
      margin-bottom: 0;
    }
    .paper-header {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
    }
    .paper-index {
      width: 24px;
      height: 24px;
      background: #4a5568;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 600;
      flex-shrink: 0;
      font-family: Arial, sans-serif;
    }
    .paper-title {
      font-size: 15px;
      font-weight: 600;
      color: #1a202c;
      line-height: 1.4;
      flex: 1;
    }
    .paper-meta {
      color: #718096;
      font-size: 12px;
      margin-bottom: 12px;
      padding-left: 34px;
    }
    .paper-section {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 12px;
      margin-bottom: 10px;
    }
    .paper-section:last-child {
      margin-bottom: 0;
    }
    .section-label {
      font-size: 12px;
      font-weight: 600;
      color: #2d3748;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-family: Arial, sans-serif;
    }
    .section-content {
      font-size: 13px;
      color: #4a5568;
      line-height: 1.7;
    }
    .arxiv-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 10px;
      padding: 8px 14px;
      background: #1a202c;
      color: #fff;
      text-decoration: none;
      font-size: 12px;
      font-weight: 500;
      border-radius: 6px;
    }
    .empty-notice {
      text-align: center;
      padding: 30px;
      color: #718096;
      font-size: 14px;
    }
    .more-papers {
      text-align: center;
      padding: 12px;
      background: #f8fafc;
      border-radius: 8px;
      color: #718096;
      font-size: 13px;
    }
    /* Footer */
    .footer {
      background: #f8fafc;
      padding: 20px 30px;
      text-align: center;
      border-top: 1px solid #e2e8f0;
    }
    .footer p {
      color: #718096;
      font-size: 13px;
    }
    .footer a {
      color: #667eea;
      text-decoration: none;
    }
    /* Mobile */
    @media (max-width: 600px) {
      body { padding: 10px; }
      .header { padding: 20px; }
      .header img { width: 40px; height: 40px; }
      .summary, .content { padding: 20px; }
      .paper-header { flex-direction: column; }
      .paper-meta { padding-left: 0; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <img src="https://raw.githubusercontent.com/PigeonDan1/paper_claw/main/assets/logo_icon.png" alt="Paper Claw Logo">
      <h1>📰 {{ project.title }}</h1>
      <div class="header-meta">
        <span class="date">{{ window.end[:10] }}</span>
        <span class="powered-by">🤖 Powered by DeepSeek v3</span>
      </div>
      <a href="https://github.com/PigeonDan1/paper_claw" class="github-link" target="_blank">
        ⭐ Star us on GitHub
      </a>
    </div>

    <!-- Notice -->
    <div class="notice-box">
      <p>💡 <strong>提示：</strong>邮件中显示前 3 篇论文预览，完整日报请查看附件 Markdown 文件。</p>
    </div>

    <!-- Summary -->
    <div class="summary">
      <h2>📊 今日速览</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="number">{{ summary.total }}</div>
          <div class="label">论文总数</div>
        </div>
        <div class="stat-card">
          <div class="number">{{ summary.counts | length }}</div>
          <div class="label">分类数量</div>
        </div>
      </div>
      <div class="category-list">
        {% for category, count in summary.counts.items() %}
        <span class="category-tag">{{ category }}: {{ count }}</span>
        {% endfor %}
      </div>
      {% if summary.headline %}
      <p style="margin-top: 15px; color: #4a5568; font-size: 13px;">💡 {{ summary.headline }}</p>
      {% endif %}
    </div>

    <!-- Content -->
    <div class="content">
      <!-- TOC -->
      <div class="toc">
        <h3>📑 分类导航</h3>
        <ul class="toc-list">
          {% for category, items in grouped.items() %}
          <li class="toc-item">
            <span class="toc-link">{{ category }}</span>
            <span class="toc-count">{{ items | length }} 篇</span>
          </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Papers by Category -->
      {% for category, items in grouped.items() %}
      <div class="category-section">
        <div class="category-header">
          <span class="category-title">🏷️ {{ category }}</span>
          <span class="paper-count">{{ items | length }} 篇</span>
        </div>
        <div class="category-body">
          {% if items %}
            {% for paper in items[:3] %}
            <div class="paper-card">
              <div class="paper-header">
                <span class="paper-index">{{ loop.index }}</span>
                <div class="paper-title">{{ paper.title_en }}</div>
              </div>
              <div class="paper-meta">
                {% if paper.authors %}👤 {{ paper.authors | join(", ") }}{% endif %}
              </div>
              <div class="paper-section">
                <div class="section-label">📝 Abstract</div>
                <div class="section-content">{{ paper.abstract_en }}</div>
              </div>
              <div class="paper-section">
                <div class="section-label">🇨🇳 中文总结</div>
                <div class="section-content">{{ paper.review.summary }}</div>
              </div>
              <a href="{{ paper.arxiv_url }}" class="arxiv-link">🔗 查看原文 →</a>
            </div>
            {% endfor %}
            {% if items | length > 3 %}
            <div class="more-papers">📎 还有 {{ items | length - 3 }} 篇论文，请查看邮件附件</div>
            {% endif %}
          {% else %}
            <div class="empty-notice">📭 今日该分类暂无新论文</div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Generated by <a href="https://github.com/PigeonDan1/paper_claw" target="_blank">Paper Claw</a> · {{ window.end[:10] }}</p>
    </div>
  </div>
</body>
</html>
